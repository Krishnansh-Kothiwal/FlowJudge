# ── API Keys ─────────────────────────────────────

NVIDIA_API_KEY=your_nvidia_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here


# ── Generator Agent ──────────────────────────────
# Preferred generation model via NVIDIA NIM

GENERATOR_PROVIDER=nvidia
GENERATOR_MODEL=moonshotai/kimi-k2.6

GENERATOR_FALLBACK_PROVIDER=gemini
GENERATOR_FALLBACK_MODEL=gemini-3.1-flash-lite


# ── Quality Critic Agent ─────────────────────────
# Gemini model for semantic evaluation and critique

CRITIC_PROVIDER=gemini
CRITIC_MODEL=gemini-3.1-flash-lite


# ── Repair Agent ─────────────────────────────────
# auto:
# 1. try generator provider first
# 2. fallback to critic provider if needed

REPAIR_PROVIDER=auto


# ── Workflow Settings ────────────────────────────

MAX_RETRIES=3

# Optional request timeout in seconds
REQUEST_TIMEOUT=60
